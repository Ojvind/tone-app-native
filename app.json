{
  "expo": {
    "name": "Sheet Music Quiz",
    "slug": "tone-app-native",
    "version": "1.4.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "se.otterbjork.ojvind.gissanoter",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "se.otterbjork.ojvind.gissanoter"
    },
    "newArchEnabled": true,
    "plugins": [
      "expo-asset",
      "expo-localization",
      "./plugins/withRevenueCatSwiftFix"
    ],
    "extra": {
      "eas": {
        "projectId": "214cb97a-c414-407c-801d-150c87759eac"
      }
    }
  }
}
